<UserControl x:Class="praktika26_Shein.Pages.Users.Elements.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:praktika26_Shein.Pages.Users.Elements"
             mc:Ignorable="d" Height="199">
    <Grid Margin="10" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100px"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Width="80" Height="80" VerticalAlignment="Top" Margin="10" Source="/Images/user.jpg" />

        <Button Click="EditUser" Height="25" Content="Изменить" VerticalAlignment="Top" Margin="10,95,10,0"
                Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White"/>

        <Button Click="DeleteUser" Height="25" Content="Удалить" VerticalAlignment="Top" Margin="10,125,10,10"
                Background="#FFCD1E1E" BorderBrush="#FFCD1E1E" Foreground="White"/>

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label VerticalAlignment="Top" Margin="10,10,10,0" Content="Дата аренды: " />
            <DatePicker x:Name="RentStart" VerticalAlignment="Top" Margin="10,35,10,0" Height="25"
                VerticalContentAlignment="Center" IsEnabled="False"/>

            <Label VerticalAlignment="Top" Margin="10,65,10,0" Content="Время аренды: " />
            <TextBox x:Name="RentTime" Text="Время аренды" VerticalAlignment="Top" Margin="10,90,10,0" Height="25"
                VerticalContentAlignment="Center" IsEnabled="False"/>

            <Label VerticalAlignment="Top" Margin="10,10,10,0" Content="Продолжительность: " Grid.Column="1" />
            <TextBox x:Name="Duration" Text="Продолжительность" VerticalAlignment="Top" Margin="10,35,10,0" Height="25"
                Grid.Column="1" VerticalContentAlignment="Center" IsEnabled="False"/>

            <Label VerticalAlignment="Top" Margin="10,65,10,0" Grid.Column="1" Content="Клуб: " />
            <TextBox x:Name="Club" Text="Наименование клуба" VerticalAlignment="Top" Grid.Column="1" Margin="10,90,10,0" Height="25"
                VerticalContentAlignment="Center" IsEnabled="False"/>

            <Label VerticalAlignment="Top" Margin="10,120,10,0" Grid.ColumnSpan="2" Content="Фамилия Имя и Отчество" />
            <TextBox x:Name="FIO" Text="Оценка Роберт Альбертович" VerticalAlignment="Top" Margin="10,145,10,0" Height="25"
                VerticalContentAlignment="Center" IsEnabled="False" Grid.ColumnSpan="2"/>
        </Grid>
    </Grid>
</UserControl>
