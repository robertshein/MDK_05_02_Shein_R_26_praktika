<Page x:Class="praktika26_Shein.Pages.Clubs.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:praktika26_Shein.Pages.Clubs"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid Margin="10" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100px"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Image Width="80" Height="80" VerticalAlignment="Top" Margin="10,40,10,0" Source="/Images/imac.jpg" />

        <Button Click="AddClub" Height="25" Content="Добавить" VerticalAlignment="Top" Margin="10,125,10,0"
            Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White"/>

        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Content="Наименование:" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,41,0,0"/>
            <TextBox x:Name="Name" Text="Наименование" VerticalAlignment="Top" Margin="10,67,10,0" Height="26"
                 VerticalContentAlignment="Center"/>

            <Label Content="Адрес:" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,97,0,0"/>
            <TextBox x:Name="Address" Text="Адрес" VerticalAlignment="Top" Margin="10,123,10,0" Height="25"
                 VerticalContentAlignment="Center"/>

            <Label Content="Время работы:" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10,41,0,0" Grid.Column="1"/>
            <TextBox x:Name="WorkTime" VerticalAlignment="Top" Margin="10,67,10,0" Height="81"
                 VerticalContentAlignment="Center" Grid.Column="1"/>
        </Grid>
        <Button Height="25" Content="Клубы" VerticalAlignment="Top" Margin="10,10,10,0"
            Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White"/>
        <Button Height="25" Content="Пользователи" VerticalAlignment="Top" Margin="10,10,590,0"
            Background="#FF46FD00" BorderBrush="#FF46FD00" Foreground="White" Grid.Column="1"/>
    </Grid>
</Page>
